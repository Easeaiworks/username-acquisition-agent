# =============================================================================
# Sean Lead Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.
# =============================================================================

# --- Supabase (REQUIRED) ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Claude API (REQUIRED) ---
ANTHROPIC_API_KEY=sk-ant-your-key

# --- Security ---
DASHBOARD_API_KEY=            # Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
REQUIRE_AUTH=false             # Set to true in production
ALLOWED_ORIGINS=               # Comma-separated, e.g. https://your-app.railway.app
API_RATE_LIMIT=60              # Max requests per minute per IP
MAX_UPLOAD_SIZE_MB=10

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=

# --- Twitch Helix API ---
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# --- Apify (Instagram + TikTok scanning) ---
APIFY_API_TOKEN=

# --- Contact Enrichment ---
ROCKETREACH_API_KEY=
HUNTER_API_KEY=

# --- Email Sending (Instantly.ai or Smartlead) ---
INSTANTLY_API_KEY=
SMARTLEAD_API_KEY=

# --- Calendly ---
CALENDLY_API_KEY=
CALENDLY_EVENT_URL=https://calendly.com/sean/meeting

# --- Application Settings ---
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# --- Autonomy Thresholds ---
AUTO_OUTREACH_THRESHOLD=0.65
APPROVAL_QUEUE_THRESHOLD=0.50
DAILY_SCAN_HOUR=6
DAILY_SCAN_MINUTE=0

# --- External API Rate Limits ---
MAX_YOUTUBE_CALLS_PER_DAY=9000
MAX_TWITCH_CALLS_PER_MINUTE=25
MAX_APIFY_CONCURRENT_RUNS=3
MAX_ROCKETREACH_CALLS_PER_MONTH=3000
MAX_HUNTER_CALLS_PER_MONTH=2500

# --- Compliance ---
MAX_TOUCHES_PER_CONTACT=4
OUTREACH_COOLDOWN_DAYS=30
SENDER_EMAIL=sean@yourdomain.com
SENDER_NAME=Sean
PHYSICAL_ADDRESS=Your Business Address
