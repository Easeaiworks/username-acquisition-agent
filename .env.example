# =============================================================================
# Sean Lead Agent — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# NEVER commit the .env file to git.
# =============================================================================

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Claude API ---
ANTHROPIC_API_KEY=your-anthropic-api-key

# --- YouTube Data API v3 ---
YOUTUBE_API_KEY=your-youtube-api-key

# --- Twitch Helix API ---
TWITCH_CLIENT_ID=your-twitch-client-id
TWITCH_CLIENT_SECRET=your-twitch-client-secret

# --- Apify (Instagram + TikTok scanning) ---
APIFY_API_TOKEN=your-apify-token

# --- RocketReach ---
ROCKETREACH_API_KEY=your-rocketreach-api-key

# --- Hunter.io ---
HUNTER_API_KEY=your-hunter-api-key

# --- Email Sending (Instantly.ai or Smartlead) ---
# INSTANTLY_API_KEY=your-instantly-api-key
# SMARTLEAD_API_KEY=your-smartlead-api-key

# --- Calendly ---
# CALENDLY_API_KEY=your-calendly-api-key
# CALENDLY_EVENT_URL=https://calendly.com/sean/meeting

# --- Application Settings ---
APP_ENV=development
APP_PORT=8000
LOG_LEVEL=INFO

# --- Autonomy Thresholds ---
AUTO_OUTREACH_THRESHOLD=0.65
APPROVAL_QUEUE_THRESHOLD=0.50
DAILY_SCAN_HOUR=6
DAILY_SCAN_MINUTE=0

# --- Rate Limits ---
MAX_YOUTUBE_CALLS_PER_DAY=9000
MAX_TWITCH_CALLS_PER_MINUTE=25
MAX_APIFY_CONCURRENT_RUNS=3
MAX_ROCKETREACH_CALLS_PER_MONTH=3000
MAX_HUNTER_CALLS_PER_MONTH=2500

# --- Compliance ---
MAX_TOUCHES_PER_CONTACT=4
OUTREACH_COOLDOWN_DAYS=30
SENDER_EMAIL=your-outreach-email@domain.com
SENDER_NAME=Sean
PHYSICAL_ADDRESS=Your Business Address
